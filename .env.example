# --- Model via Zuplo AI Gateway -----------------------------------------
# agent/agent.ts routes the model through a Zuplo AI Gateway (OpenAI-compatible)
# via @ai-sdk/openai-compatible. The gateway holds the upstream provider key;
# this agent only carries the gateway key.
ZUPLO_AI_GATEWAY_URL=https://<your-ai-gateway>/v1
ZUPLO_AI_GATEWAY_KEY=
# Model id as your AI Gateway route expects it.
ZUPLO_AI_MODEL=anthropic/claude-opus-4.8

# --- MCP Gateway route --------------------------------------------------
# The single OAuth-protected gateway route the agent points at, shaped
# https://<your-gateway>/mcp/<upstream-name>. Buffer's upstream key is held by
# the gateway, never by this agent.
MCP_GATEWAY_URL=https://mcp.acme.dev/mcp/buffer

# --- OAuth issuer (optional) --------------------------------------------
# The gateway's authorization server, where `npm run bootstrap` and the runtime
# discover the OAuth endpoints (RFC 8414). For the Zuplo MCP Gateway the issuer
# IS the route, so this defaults to MCP_GATEWAY_URL. Set it only if your
# deployment puts the authorization server on a separate origin.
# MCP_OAUTH_ISSUER=https://auth.acme.dev

# No client id/secret here: `npm run bootstrap` registers a public client via
# dynamic client registration and stores the client_id + refresh token in
# .eve/oauth-store.json. Run it once, then the agent runs headless.
